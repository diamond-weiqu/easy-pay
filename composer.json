{
    "name": "moxianbao/easy-pay",
    "description": "Framework-agnostic PHP payment SDK for Alipay, Wechat Pay, Leshua, and Lakala with unified gateway APIs.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "payment",
        "pay",
        "gateway",
        "alipay",
        "wechat-pay",
        "wechatpay",
        "leshua",
        "lakala",
        "php-sdk",
        "sdk",
        "easy-pay"
    ],
    "require": {
        "php": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "EasyPay\\Payment\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EasyPay\\Payment\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
